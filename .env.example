# Radio Calico — Environment variables
# REQUIRED: Copy this file to .env and set real values before running Docker.
#
#   cp .env.example .env
#   # Edit .env with your passwords
#   docker compose --profile dev up --build

# MySQL root password (Docker initialization only)
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_password

# Application database credentials
DB_USER=rcapp
DB_PASSWORD=CHANGE_ME_app_password
DB_NAME=radiocalico

# Flask configuration
FLASK_DEBUG=false

# CORS allowed origin (set to your domain in production)
CORS_ORIGIN=http://127.0.0.1:5050

# Host port mapping (container always uses 5000 internally)
APP_PORT=5050
