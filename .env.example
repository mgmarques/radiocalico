# Radio Calico — Docker environment variables
# Copy this file to .env and customize:  cp .env.example .env

# MySQL root password (used only by Docker to initialize the DB)
MYSQL_ROOT_PASSWORD=rootsecret

# Application database credentials
DB_USER=rcapp
DB_PASSWORD=radiocalico
DB_NAME=radiocalico

# Flask configuration
FLASK_DEBUG=false

# CORS allowed origin (set to your domain in production)
CORS_ORIGIN=http://127.0.0.1:5050

# Host port mapping (container always uses 5000 internally)
APP_PORT=5050
