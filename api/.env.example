DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=radiocalico
FLASK_DEBUG=false
CORS_ORIGIN=*

# LLM (Ollama) — set to host Ollama for GPU acceleration on macOS
# Docker default falls back to the containerized Ollama (CPU-only, slower)
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
# OLLAMA_MODEL=llama3.2
# OLLAMA_API_KEY=ollama
#
# Cloud provider examples (see README.md for full list):
# Groq (free tier):  OLLAMA_BASE_URL=https://api.groq.com/openai/v1  OLLAMA_API_KEY=gsk_...  OLLAMA_MODEL=llama-3.3-70b-versatile
# OpenAI:            OLLAMA_BASE_URL=https://api.openai.com/v1        OLLAMA_API_KEY=sk-...   OLLAMA_MODEL=gpt-4o-mini
# Together AI:       OLLAMA_BASE_URL=https://api.together.xyz/v1      OLLAMA_API_KEY=...      OLLAMA_MODEL=meta-llama/Llama-3.2-3B-Instruct-Turbo
